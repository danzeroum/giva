# Copie para .env (dev local) — Vite lê VITE_* automaticamente.
# Embutida no bundle em build-time; não é segredo, é só o endereço da API.
VITE_API_URL=http://localhost:8000

# Modo demo: 'true' liga a UI de demonstração (dados fictícios, sem backend).
# Default desligado — produção usa a API real. Ligue só para telas de demo.
VITE_DEMO_MODE=false
