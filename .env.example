# Copie para .env e ajuste antes de subir (docker compose up -d --build).
# Nunca comite o .env com segredos reais.

# Senha do Postgres (troque antes de ir para produção/VPS).
POSTGRES_PASSWORD=troque-esta-senha

# Segredo simétrico do JWT (ADR-07). Gere com: openssl rand -hex 32
JWT_SECRET=

# Origens permitidas no CORS (frontend).
CORS_ORIGINS=http://localhost:8080

# Portas expostas (opcionais — defaults no docker-compose.yml).
# DB_PORT=5432
# API_PORT=8000
# FRONTEND_PORT=8080

# URL da API que o frontend consome no build.
VITE_API_URL=http://localhost:8000
